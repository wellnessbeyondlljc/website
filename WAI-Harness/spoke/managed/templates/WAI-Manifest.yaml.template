# WAI Manifest - Extension Registry Entry
# Auto-generated by Wheelwright Framework v2
# See: hub/REGISTRY-STRUCTURE.md

extension_id: "${EXTENSION_ID}"
extension_type: "${EXTENSION_TYPE}"  # spoke | project | hub
extension_name: "${EXTENSION_NAME}"

framework_version: "2.0.0"
schema_version: "2.0.0"

paths:
  root: "${EXTENSION_ROOT}"
  state: "WAI-Spoke/WAI-State.json"
  lugs: "WAI-Spoke/WAI-Lugs.jsonl"
  observations: "WAI-Spoke/observations.jsonl"
  session_log: "WAI-Spoke/WAI-Session-Log.jsonl"

metadata:
  created: "${TIMESTAMP}"
  last_updated: "${TIMESTAMP}"
  git_integrated: ${GIT_INTEGRATED}
  machine_class: "${MACHINE_CLASS}"  # HIGH-PERFORMANCE | STANDARD | LOW-POWER

skills_loaded:
  framework:
    - safe-refactor
    - qc-check
    - hub-watcher
    - framework-updater
    - brief-advisor
    - session-observer
    - file-audit
    - integration-check
  spoke: []  # Add spoke-specific skill overrides here

signals:
  pev_active: true
  complexity_gate_enabled: true
  context_warnings_enabled: true
  stewardship_advisor_enabled: true

hub:
  hub_path: "${HUB_PATH}"
  hub_lug_cursor: 0  # Last processed Hub Lug ID
  cross_node_signals: false  # Enable if participating in cross-node learning

integration:
  ide: "claude-code"
  ide_version: "${IDE_VERSION}"
  optimized: ${OPTIMIZED}  # IDE settings optimized for machine class
