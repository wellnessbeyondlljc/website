{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Escalation Routing Event",
  "type": "object",
  "required": ["event_type", "track", "interrupt", "payload"],
  "properties": {
    "event_type": {
      "type": "string",
      "enum": ["wave_complete", "error_blocking", "decision_required", "stale_lug", "lug_completed", "epic_completed", "initiative_completed"],
      "description": "The type of notification event"
    },
    "track": {
      "type": "string",
      "enum": ["internal", "external"],
      "description": "Which track this event routes through"
    },
    "interrupt": {
      "type": "boolean",
      "description": "Whether this event interrupts the current session flow"
    },
    "level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 7,
      "description": "Escalation level (0=silent, 1=badge, 2=session prompt, 3=agent question, 4=telegram push, 5=telegram priority, 6=email digest, 7=call)"
    },
    "payload": {
      "type": "object",
      "description": "Event-specific data",
      "properties": {
        "message": {"type": "string"},
        "entity_id": {"type": ["string", "null"]},
        "entity_type": {"type": ["string", "null"]},
        "severity": {"type": "string", "enum": ["info", "warning", "error"]}
      },
      "required": ["message", "severity"]
    },
    "tastegraph_ref": {
      "type": ["string", "null"],
      "description": "ID of the TasteGraph preference that governed this routing decision"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
