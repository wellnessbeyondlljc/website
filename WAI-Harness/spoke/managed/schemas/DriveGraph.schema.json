{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "DriveGraph",
  "title": "DriveGraph",
  "description": "Hub and spoke drive model: nested drives with horizons, richness, themes, and achieved archiving.",
  "type": "object",
  "required": ["schema_version", "scope", "last_updated", "themes", "drives", "drive_archive"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver — bump minor on schema additions, major on breaking changes."
    },
    "scope": {
      "type": "string",
      "enum": ["hub", "spoke"],
      "description": "hub = Wheel-level drives and canonical themes. spoke = extends hub."
    },
    "inherits_from": {
      "type": ["string", "null"],
      "description": "For spoke files: 'hub'. For hub file: null."
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of last write."
    },
    "themes": {
      "type": "array",
      "description": "Cross-cutting theme registry. Hub defines canonical themes; spokes may extend with local themes or leave empty to inherit hub themes.",
      "items": {
        "type": "object",
        "required": ["theme_id", "label", "description"],
        "additionalProperties": false,
        "properties": {
          "theme_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Kebab-case unique identifier."
          },
          "label": {
            "type": "string",
            "description": "Human-readable display name."
          },
          "description": {
            "type": "string",
            "description": "What this theme represents."
          },
          "arc": {
            "type": ["string", "null"],
            "description": "Narrative summary of where this theme is headed across the Wheel."
          }
        }
      }
    },
    "drives": {
      "type": "array",
      "description": "Active and paused drives. Achieved and abandoned drives move to drive_archive.",
      "items": { "$ref": "#/definitions/drive" }
    },
    "drive_archive": {
      "type": "array",
      "description": "Drives with status=achieved or status=abandoned. Same shape as drives. Preserved for theme threading and history.",
      "items": { "$ref": "#/definitions/drive" }
    }
  },
  "definitions": {
    "drive": {
      "type": "object",
      "required": ["drive_id", "title", "themes", "horizon", "status", "completion", "direction"],
      "additionalProperties": false,
      "properties": {
        "drive_id": {
          "type": "string",
          "pattern": "^(hub:)?drive-[a-z0-9-]+-v\\d+$",
          "description": "Format: drive-{slug}-v{n}. Hub reference prefix: hub:{drive_id}."
        },
        "title": {
          "type": "string",
          "minLength": 3
        },
        "themes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "theme_id references. May be empty."
        },
        "horizon": {
          "type": "string",
          "enum": ["now", "soon", "later", "next_version", "unscheduled"],
          "description": "Named stage. Coarse sort order: now < soon < later < next_version < unscheduled."
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "paused", "achieved", "abandoned"]
        },
        "parent_drive": {
          "type": ["string", "null"],
          "description": "hub:{drive_id} to extend/override a hub drive. null for standalone drives."
        },
        "override": {
          "type": "boolean",
          "default": false,
          "description": "false = extend parent hub drive. true = replace parent hub drive for this spoke context."
        },
        "activation": {
          "type": "object",
          "required": ["trigger"],
          "additionalProperties": false,
          "properties": {
            "trigger": {
              "type": "string",
              "enum": ["manual", "dependency", "signal", "time", "condition"]
            },
            "active_when": {
              "type": ["string", "null"],
              "description": "Human-readable condition that activates this drive."
            },
            "dormant_when": {
              "type": ["string", "null"],
              "description": "Human-readable condition that pauses this drive."
            }
          }
        },
        "completion": {
          "type": "object",
          "required": ["horizon", "richness", "milestones", "gap"],
          "additionalProperties": false,
          "properties": {
            "horizon": {
              "type": "string",
              "enum": ["now", "soon", "later", "next_version", "unscheduled"],
              "description": "Same as drive.horizon — source of truth here."
            },
            "richness": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "description": "Fine sort order within horizon. 0.0 = just entered stage. 1.0 = ready to promote to next horizon."
            },
            "milestones": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "title", "done"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string" },
                  "title": { "type": "string" },
                  "done": { "type": "boolean" },
                  "confirmed_by": {
                    "type": ["string", "null"],
                    "enum": ["user", "agent", null],
                    "description": "null = draft (not yet confirmed)."
                  }
                }
              }
            },
            "gap": {
              "type": "string",
              "description": "What is still missing before this drive can advance to the next horizon."
            },
            "iterations_planned": {
              "type": ["integer", "null"],
              "minimum": 0
            }
          }
        },
        "direction": {
          "type": "object",
          "required": ["next_step"],
          "additionalProperties": false,
          "properties": {
            "current_approach": { "type": ["string", "null"] },
            "data_gathering": { "type": ["string", "null"] },
            "next_step": {
              "type": "string",
              "description": "The concrete next action for this drive."
            },
            "recommendations_for_user": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
